# Server-only Resend API key. Never prefix this with VITE_.
RESEND_API_KEY=re_xxxxxxxxx

# Verified Resend sender. Must be from a domain configured in Resend.
RESEND_FROM=BetaQuill <hello@your-domain.com>

# Optional reply-to address for the confirmation email.
RESEND_REPLY_TO=

# Add new contacts to the BetaQuill waitlist segment.
RESEND_WAITLIST_SEGMENT_ID=seg_xxxxxxxxx

# Public Supabase credentials. These are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public analytics config.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
