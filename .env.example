# Server-only Resend API key. Never prefix this with VITE_.
RESEND_API_KEY=re_xxxxxxxxx

# Verified Resend sender. Must be from a domain configured in Resend.
RESEND_FROM=BetaManuscript <hello@your-domain.com>

# Optional reply-to address for the confirmation email.
RESEND_REPLY_TO=

# Add new contacts to the BetaManuscript waitlist segment.
RESEND_WAITLIST_SEGMENT_ID=seg_xxxxxxxxx

# Public Supabase credentials. These are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional canonical app URL for transactional links. The current request host
# is used in local development when this is empty.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public analytics config.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Stripe. The secret key must only be used from server-side code.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxx
STRIPE_BETAMANUSCRIPT_PRO_PRICE_ID=price_xxxxxxxxx
